# Dermalens OCR 환경변수 예시
# 실제 값을 채운 뒤 파일명을 .env 로 복사해서 사용하세요.
#   cp .env.example .env   (Windows: copy .env.example .env)
# .env 는 git 에 커밋하지 마세요 (.gitignore 에 포함됨).

# ── Google Cloud Vision (OCR 엔진) ──────────────────────────
# 서비스 계정 JSON 키 파일 경로 (절대/상대 경로 모두 가능)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-vision-key.json

# ── OpenAI (GPT 정밀 분류/추출) ─────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# ── Anthropic (선택: claude 모듈 사용 시) ────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── 공공데이터포털 성분 API ─────────────────────────────────
PUBLIC_DATA_API_KEY=your_public_data_portal_key
COSMETIC_INGREDIENT_API_URL=https://api.odcloud.kr/api/your-endpoint

# ── 백엔드 결과 전송 (서버용) ───────────────────────────────
# OCR 결과(POST /ocr 처리 후)를 전달할 백엔드 엔드포인트.
# 비워두면 분석은 수행하되 백엔드 전송은 생략한다.
BACKEND_OCR_RESULT_URL=http://localhost:8000/api/analysis/ocr-result/
